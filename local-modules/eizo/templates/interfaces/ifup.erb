# Managed by puppet

auto <%= @name %>
<% for family in ["inet", "inet6"] %>
<% if @static[family] then -%>
iface <%= @name %> <%= family %> static
  address <%= @static[family] %>
<% if @gateway[family] then -%>
  gateway <%= @gateway[family] %>
<% end -%>
<% if @vlan then -%>
  pre-up    ip link add link <%= @vlan["over"] %> name <%= @name %> type vlan id <%= @vlan["id"] %>
  post-down ip link del <%= @name %>
<% end -%>
<% @also.each do |name, value| -%>
  <%= name %> <%= value %>
<% end -%>
<% end -%>
<% end -%>
